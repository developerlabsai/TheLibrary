{
  "name": "@devlabs/speckit-deployer",
  "version": "1.0.0",
  "description": "SpecKit Deployer - Uniform deployment of SpecKit, Beads, Agents, Specialties, MCP Servers, and Templates",
  "type": "module",
  "bin": {
    "speckit": "./dist/bin/speckit.js"
  },
  "files": [
    "dist/",
    "library/",
    "Agents/",
    "Skills/",
    "Specialties/",
    "Templates/",
    "Packages/",
    "Teams/",
    "dashboard/dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx bin/speckit.ts",
    "start": "node dist/bin/speckit.js",
    "lint": "tsc --noEmit",
    "prepublishOnly": "cd ../dashboard && npm run build && cd ../deployer && tsc && node scripts/add-shebang.js"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "yaml": "^2.5.0",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
